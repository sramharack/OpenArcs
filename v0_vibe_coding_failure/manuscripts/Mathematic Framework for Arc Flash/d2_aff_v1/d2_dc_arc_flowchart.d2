# DC Arc Flash Iterative Solution Algorithm
# D2 Diagram - Professional flowchart style

direction: down

# Nodes
start: START {
  shape: oval
  style.fill: "#E8F4EA"
  style.stroke: "#2E7D32"
}

input: "Input Parameters\n- System voltage (Vsys)\n- System resistance (Rsys)\n- Electrode gap (G)" {
  shape: parallelogram
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
}

init: "Initial Estimate\nIarc = 0.5 × Ibf\nwhere Ibf = Vsys / Rsys" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}

iter_start: "Set iteration k = 0" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}

calc_rarc: "Calculate Arc Resistance\nRarc = (20 + 0.534·G) / Iarc^0.88\n(Stokes-Oppenlander)" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}

calc_iarc: "Calculate New Arc Current\nIarc(k+1) = Vsys / (Rsys + Rarc)" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}

converge: "Converged?\n|delta Iarc| < 0.1%" {
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
}

increment: "k = k + 1" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}

calc_power: "Calculate Arc Power\nParc = Iarc² × Rarc" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}

calc_energy: "Calculate Incident Energy\nE = (Parc × t) / (4π D²)" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}

output: "Output Results\n- Arc current: Iarc\n- Arc resistance: Rarc\n- Incident energy: E" {
  shape: parallelogram
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
}

end: END {
  shape: oval
  style.fill: "#E8F4EA"
  style.stroke: "#2E7D32"
}

# Connections
start -> input
input -> init
init -> iter_start
iter_start -> calc_rarc
calc_rarc -> calc_iarc
calc_iarc -> converge
converge -> increment: No
increment -> calc_rarc
converge -> calc_power: Yes
calc_power -> calc_energy
calc_energy -> output
output -> end
