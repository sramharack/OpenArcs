# IEEE 1584-2018 Arc Flash Calculation Workflow
# D2 Diagram - Comprehensive calculation flowchart

direction: down

# Start
start: "START\nArc Flash Analysis" {
  shape: oval
  style.fill: "#1565C0"
  style.stroke: "#0D47A1"
  style.font-color: "#FFFFFF"
}

# Input section
inputs: "Gather Input Data\n- System voltage (Voc)\n- Bolted fault current (Ibf)\n- Electrode configuration\n- Electrode gap (G)\n- Enclosure dimensions\n- Working distance (D)" {
  shape: rectangle
  style.fill: "#FFECB3"
  style.stroke: "#FF8F00"
}

# Decision - voltage range
voltage_check: "System Voltage\nWithin 208V-15kV?" {
  shape: diamond
  style.fill: "#FCE4EC"
  style.stroke: "#C2185B"
}

outside_range: "Use Alternative Method\n- DC: Stokes-Oppenlander\n- >15kV: EPRI/Terzija\n- Single-phase: Conservative" {
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
}

# Voltage branch
lv_check: "Voltage <= 600V?" {
  shape: diamond
  style.fill: "#FCE4EC"
  style.stroke: "#C2185B"
}

# Arcing current calculation
calc_iarc_lv: "LV Arc Current\nCalculate Iarc,600 using\nTable 1 coefficients" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}

calc_iarc_mv: "MV Arc Current\nCalculate Iarc at 600V,\n2700V, and 14300V" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}

interpolate_iarc: "Interpolate Arc Current\nto actual voltage Voc" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}

# Arc current variation
calc_varcf: "Calculate Variation Factor\nVarCf = f(Iarc, Voc)\nIarc,min = Iarc(1 - 0.5·VarCf)" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}

# Protection coordination
get_time: "Determine Arc Duration\nFrom protection TCC\nat Iarc and Iarc,min" {
  shape: rectangle
  style.fill: "#FFECB3"
  style.stroke: "#FF8F00"
}

# Incident energy
calc_ie: "Calculate Incident Energy\nat both Iarc and Iarc,min\nApply enclosure correction" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}

select_max: "Select Maximum\nE = max(E_Iarc, E_Iarc,min)" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}

# Arc flash boundary
calc_afb: "Calculate Arc Flash Boundary\nAFB = D × (E/1.2)^(1/x)" {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}

# Output
results: "RESULTS\n- Incident Energy (cal/cm²)\n- Arc Flash Boundary (mm)\n- PPE Category" {
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
}

end: END {
  shape: oval
  style.fill: "#1565C0"
  style.stroke: "#0D47A1"
  style.font-color: "#FFFFFF"
}

# Connections
start -> inputs
inputs -> voltage_check
voltage_check -> outside_range: No
voltage_check -> lv_check: Yes
lv_check -> calc_iarc_lv: Yes
lv_check -> calc_iarc_mv: No
calc_iarc_lv -> calc_varcf
calc_iarc_mv -> interpolate_iarc
interpolate_iarc -> calc_varcf
calc_varcf -> get_time
get_time -> calc_ie
calc_ie -> select_max
select_max -> calc_afb
calc_afb -> results
results -> end
outside_range -> end
