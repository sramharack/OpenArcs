direction: down

title: |md
  # DC Arc Flash Calculation Method
  Based on Industry References (Ammerman, Das, Doan, NFPA 70E)
| {near: top-center}

dc_start: DC System Arc Flash\nAnalysis Required {
  shape: oval
  style.fill: "#e8f5e9"
}

dc_warning: ⚠ IEEE 1584-2018\nNOT Applicable for DC {
  shape: rectangle
  style.fill: "#ffebee"
  style.bold: true
}

dc_refs: Consult DC-Specific\nReferences {
  shape: rectangle
  style.fill: "#fff3e0"
}
dc_refs.items: |md
  - Ammerman et al. (IEEE Trans IA 2010)
  - Das (IEEE Trans IA 2014)
  - Doan DC methods
  - NFPA 70E Annex D.6
  - Klement (solar PV)
|

dc_collect: Collect DC System Data {
  shape: rectangle
}
dc_collect.1: "- DC voltage (Vdc)"
dc_collect.2: "- Maximum available fault current"
dc_collect.3: "- System capacitance"
dc_collect.4: "- Cable inductance"
dc_collect.5: "- Working distance"
dc_collect.6: "- Electrode gap"

dc_method_select: Select Calculation Method {
  shape: diamond
  style.fill: "#e3f2fd"
}

# Method 1: Ammerman/Das Approach
method1: Ammerman/Das Method {
  shape: rectangle
  style.fill: "#e1f5fe"
}

dc_arc_voltage: Calculate DC Arc Voltage\nVarc = 1.94 + 0.0368×L {
  shape: rectangle
}
dc_arc_voltage.note: "L = arc length (mm)\nTypically L ≈ gap"

dc_arc_current: Calculate DC Arc Current\nIarc = (Vdc - Varc) / Zsys {
  shape: rectangle
}
dc_arc_current.note: "Zsys = system impedance"

dc_arc_power: Calculate Arc Power\nParc = Varc × Iarc {
  shape: rectangle
}

# Method 2: Simplified NFPA Approach
method2: Simplified NFPA 70E\nAnnex D.6 Method {
  shape: rectangle
  style.fill: "#f3e5f5"
}

nfpa_iarc: Use AC Model for Iarc\n(Conservative Estimate) {
  shape: rectangle
}
nfpa_iarc.note: "Apply IEEE 1584 Eq 1\nwith Voc = Vdc"

nfpa_adjust: Adjust for DC\nCharacteristics {
  shape: rectangle
}
nfpa_adjust.items: |md
  - No zero crossings
  - Sustained arc
  - Longer clearing times
  - Energy storage effects
|

# Method 3: Three-phase AC Equivalent
method3: Three-Phase AC\nEquivalent Method {
  shape: rectangle
  style.fill: "#fff9c4"
}

ac_equiv: Convert DC to\nEquivalent AC {
  shape: rectangle
}
ac_equiv.formula: "Vac_equiv ≈ Vdc / 1.414\nIac_equiv ≈ Idc"

apply_1584: Apply IEEE 1584-2018\nwith Equivalent Values {
  shape: rectangle
}

correction: Apply DC\nCorrection Factor {
  shape: rectangle
}
correction.note: "Typically 1.2-1.5×\n(conservative)"

# Common path
dc_duration: Determine DC Arc Duration {
  shape: rectangle
  style.fill: "#ffccbc"
}
dc_duration.items: |md
  - Protective device time
  - No current zero crossing
  - May need active detection
  - Consider arc sustainability
|

dc_energy: Calculate Incident Energy {
  shape: rectangle
}
dc_energy.formula: |md
  E = (Parc × t) / (4π × D²) × CF
  
  where:
  - Parc = arc power (W)
  - t = arc duration (s)
  - D = working distance (mm)
  - CF = configuration factor
|

dc_afb: Calculate Arc-Flash\nBoundary {
  shape: rectangle
}
dc_afb.formula: |md
  AFB = √[(Parc × t) / (4π × Eb)]
  
  where Eb = 5.0 J/cm² threshold
|

# Special considerations
dc_special: DC-Specific Considerations {
  shape: rectangle
  style.fill: "#d7ccc8"
}
dc_special.1: "✓ Battery systems: discharge curves"
dc_special.2: "✓ Solar PV: module contributions"
dc_special.3: "✓ Capacitor discharge energy"
dc_special.4: "✓ Arc detection systems"
dc_special.5: "✓ Longer sustained arcs"

dc_conservative: Apply Conservative\nSafety Factors {
  shape: rectangle
  style.fill: "#ffccbc"
}
dc_conservative.note: "1.5-2.0× multiplier\ndue to model uncertainty"

dc_output: DC Arc Flash Results {
  shape: rectangle
  style.fill: "#c8e6c9"
}
dc_output.1: "- Estimated Iarc"
dc_output.2: "- Incident Energy (J/cm²)"
dc_output.3: "- Arc-Flash Boundary"
dc_output.4: "- ⚠ Conservative estimates"
dc_output.5: "- Method & references used"

dc_end: Complete DC Analysis {
  shape: oval
  style.fill: "#ffcdd2"
}

# Connections
dc_start -> dc_warning
dc_warning -> dc_refs
dc_refs -> dc_collect
dc_collect -> dc_method_select

dc_method_select -> method1: "Ammerman/Das"
dc_method_select -> method2: "NFPA"
dc_method_select -> method3: "AC Equiv"

# Method 1 path
method1 -> dc_arc_voltage
dc_arc_voltage -> dc_arc_current
dc_arc_current -> dc_arc_power
dc_arc_power -> dc_duration

# Method 2 path
method2 -> nfpa_iarc
nfpa_iarc -> nfpa_adjust
nfpa_adjust -> dc_duration

# Method 3 path
method3 -> ac_equiv
ac_equiv -> apply_1584
apply_1584 -> correction
correction -> dc_duration

# Common path
dc_duration -> dc_special
dc_special -> dc_energy
dc_energy -> dc_afb
dc_afb -> dc_conservative
dc_conservative -> dc_output
dc_output -> dc_end

# Warning box
dc_caution: ⚠ CAUTION {
  shape: rectangle
  style.fill: "#ffebee"
  style.bold: true
  near: bottom-right
}
dc_caution.text: |md
  DC arc flash calculations
  have significant uncertainty.
  
  Always:
  • Use multiple methods
  • Apply safety factors
  • Consult specialists
  • Consider testing
|