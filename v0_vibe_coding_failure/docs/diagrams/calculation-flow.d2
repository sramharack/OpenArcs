
title: Arc Flash Calculation Flow - IEEE 1584-2018 {
  near: top-center
  shape: text
  style.font-size: 20
  style.bold: true
}

# Input Stage
input: User Input {
  style.fill: "#dbeafe"
  style.stroke: "#3b82f6"
  
  params: |md
    - Voltage (V)
    - Fault Current (A)
    - Working Distance (in)
    - Enclosure Type
    - Gap (mm)
    - Clearing Time (s)
  |
}

# Validation
validation: Input Validation {
  style.fill: "#fef3c7"
  style.stroke: "#f59e0b"
  
  checks: |md
    ✓ 208V ≤ V ≤ 15kV
    ✓ Ibf < 106 kA
    ✓ D > 0
    ✓ All required fields
  |
}

# Arcing Current
arcing: Arcing Current\nCalculation {
  style.fill: "#dcfce7"
  style.stroke: "#10b981"
  
  equation: |md
    **IEEE Equation 4a**
    lg(Ia) = K + 0.662×lg(Ibf)
            + 0.0966×V
            + other terms...
    
    Result: Ia (Amperes)
  |
}

# Incident Energy
energy: Incident Energy\nCalculation {
  style.fill: "#fce7f3"
  style.stroke: "#ec4899"
  
  equation: |md
    **IEEE Equation 6**
    E = (Cf × Ia × V × t) / D²
    
    Result: E (cal/cm²)
  |
}

# PPE
ppe: PPE Category\nDetermination {
  style.fill: "#e0e7ff"
  style.stroke: "#6366f1"
  
  table: |md
    **NFPA 70E Table 130.5(G)**
    Cat 0: < 1.2 cal/cm²
    Cat 1: 1.2-4
    Cat 2: 4-8
    Cat 3: 8-25
    Cat 4: > 25
  |
}

# Boundary
boundary: Arc Flash Boundary {
  style.fill: "#fed7aa"
  style.stroke: "#f97316"
  
  calc: |md
    Distance where E = 1.2 cal/cm²
    
    Solves for D in energy equation
  |
}

# Output
output: Results & Report {
  style.fill: "#f3e8ff"
  style.stroke: "#a855f7"
  
  includes: |md
    - Incident Energy
    - PPE Category
    - Arc Flash Boundary
    - Warnings
    - Label Data
  |
}

# Flow
input -> validation: Submit
validation -> arcing: Valid
arcing -> energy: Ia
energy -> ppe: E
energy -> boundary: E
ppe -> output: Category
boundary -> output: AFB

# Error path
validation -> input: Invalid {
  style.stroke: "#ef4444"
  style.stroke-dash: 3
}

# Legend
legend: |md
  ## Color Key
  - Blue: Input/Output
  - Yellow: Validation
  - Green: IEEE Calculations
  - Pink: Energy Analysis
  - Purple: Results
| {
  near: bottom-right
  shape: text
  style.font-size: 12
}
